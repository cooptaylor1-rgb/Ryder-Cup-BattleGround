# Golf Ryder Cup App - Environment Variables
# Copy this file to .env.local and fill in your values

# ======================================
# REQUIRED - Supabase Configuration
# ======================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (for server-side operations - keep secret!)
# Get from: Supabase Dashboard > Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ======================================
# REQUIRED - Application Configuration
# ======================================

# Production URL (for CORS, OG images, share links).
#
# CRITICAL: Supabase auth uses this as the redirect base for password-reset
# and magic-link emails. If this is wrong, the email link in the user's
# inbox will go to a domain that doesn't exist (or to localhost). After
# changing it in Railway, also add `<NEXT_PUBLIC_APP_URL>/auth/callback`
# AND `<NEXT_PUBLIC_APP_URL>/auth/reset-password` to the Supabase project's
# allow-list at: Auth → URL Configuration → Redirect URLs.
NEXT_PUBLIC_APP_URL=https://ryder-cup-battleground.app

# ======================================
# REQUIRED - Push Notifications (VAPID Keys)
# ======================================
# Generate with: npx web-push generate-vapid-keys

NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your-email@example.com

# ======================================
# REQUIRED - Error Monitoring (Sentry)
# ======================================
# Get from: sentry.io > Settings > Projects > Client Keys

NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=golf-ryder-cup

# Release tagging — set in CI/Railway to the git SHA so errors map to deploys.
# Railway fallback: next.config.ts uses RAILWAY_GIT_COMMIT_SHA when this is empty.
NEXT_PUBLIC_SENTRY_RELEASE=
# Optional: explicit environment tag (defaults to NODE_ENV)
NEXT_PUBLIC_SENTRY_ENV=production

# ======================================
# REQUIRED IN RAILWAY PRODUCTION/STAGING - Health + Rate Limiting
# ======================================

# Keep strict health enabled in Railway so missing Supabase, Redis,
# service-role config, or migration markers fail the deploy health check.
HEALTHCHECK_STRICT=1

# Distributed limiter. Use Upstash Redis REST or any Redis REST service
# compatible with /pipeline and /ping bearer-token calls.
RATE_LIMIT_BACKEND=redis-rest
RATE_LIMIT_REDIS_REST_URL=https://your-redis-rest-url
RATE_LIMIT_REDIS_REST_TOKEN=your-redis-rest-token

# ======================================
# OPTIONAL - API Keys
# ======================================

# Golf Course API (for course lookups - golfcourseapi.com)
GOLF_COURSE_API_KEY=

# GHIN API (for handicap lookups - USGA)
GHIN_API_KEY=

# RapidAPI Golf Course Finder (for course search)
# Get key from: https://rapidapi.com/golf-course-finder
RAPIDAPI_KEY=

# ======================================
# OPTIONAL - AI Features
# ======================================

# Anthropic Claude API (for scorecard OCR)
ANTHROPIC_API_KEY=

# OpenAI API (alternative OCR provider)
OPENAI_API_KEY=
